# OAuth 2.1 Configuration (production)
OAUTH_ISSUER_URL=https://your-auth-provider.com/
OAUTH_JWKS_URL=https://your-auth-provider.com/.well-known/jwks.json
OAUTH_AUDIENCE=https://mcp.ghostlabs.ai
OAUTH_RESOURCE_URL=https://mcp.ghostlabs.ai

# Static API Keys (development fallback — comma-separated)
MCP_API_KEYS=dev-key-1,dev-key-2

# Product API URLs
PHANTOM_API_URL=http://phantom-backend:8000/api
